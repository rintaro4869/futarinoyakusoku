{
  "name": "futari-no-yakusoku",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @fny/db migrate",
    "db:seed": "pnpm --filter @fny/db seed",
    "db:generate": "pnpm --filter @fny/db generate"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}

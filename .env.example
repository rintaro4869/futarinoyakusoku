# ===== ローカル開発 =====
# Database (ローカル PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/futari_no_yakusoku"

# JWT
JWT_SECRET="change-me-in-production-min-32-chars"

# API
PORT=3001
APP_URL="http://localhost:3000"
WEB_URL="http://localhost:3000"
APP_VERSION="1.0.0"

# Web
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== Cloudflare デプロイ（本番）=====
# 以下は wrangler secret put で設定する（.env に書かない）
#
# [API Worker secrets]
# wrangler secret put DATABASE_URL
#   → "postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# wrangler secret put JWT_SECRET
#   → ランダム32文字以上の文字列
#
# [Cloudflare Pages env vars] (ダッシュボード or wrangler pages deploy で設定)
# NEXT_PUBLIC_API_URL = "https://futari-no-yakusoku-api.workers.dev/api/v1"
